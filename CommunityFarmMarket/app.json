{
  "expo": {
    "name": "Community Farm Market",
    "slug": "community-farm-market",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E7D32"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.communityfarmmarket.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#2E7D32"
      },
      "package": "com.communityfarmmarket.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Community Farm Market to use your location to find nearby farmers and sellers."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Community Farm Market to access your photos to upload product images.",
          "cameraPermission": "Allow Community Farm Market to access your camera to take product photos."
        }
      ]
    ]
  }
}
